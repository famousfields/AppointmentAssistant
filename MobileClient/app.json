{
  "expo": {
    "name": "Appointment Assistant",
    "slug": "swift-job-assistant-axion-9f3",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "appointmentassistant",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1d"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "ios": {
      "bundleIdentifier": "com.appointmentassistant.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.appointmentassistant.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f1d"
      }
    },
    "extra": {
      "eas": {
        "projectId": "2866cd1c-d38e-4e56-9270-daac3fd8fb67"
      }
    },
    "owner": "swift-job-assistant-axion-9f3"
  }
}
